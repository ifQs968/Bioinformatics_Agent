{
  "_instructions": "Variant Ontology Dictionary。按检索层级组织变异类型，而非按突变机制分类。patterns 为正则表达式片段，用于 PubMed、PMC、ClinicalTrials、COSMIC、ClinVar、OncoKB 等数据库文本匹配。",

  "snv": {

    "description": "Single Nucleotide Variants",

    "subtypes": {

      "missense": {
        "description": "Missense mutation",
        "patterns": [
          "missense",
          "missense mutation",
          "错义",
          "[A-Z]\\d+[A-Z]",
          "p\\.[A-Za-z]{3}\\d+[A-Za-z]{3}"
        ],
        "examples": [
          "BRAF V600E",
          "KRAS G12D",
          "EGFR L858R",
          "p.Val600Glu"
        ]
      },

      "nonsense": {
        "description": "Nonsense mutation",
        "patterns": [
          "nonsense",
          "stop.?gain",
          "stopgain",
          "premature stop",
          "truncating",
          "无义",
          "\\*",
          "Ter"
        ],
        "examples": [
          "TP53 R213*",
          "p.Arg213Ter"
        ]
      },

      "synonymous": {
        "description": "Synonymous mutation",
        "patterns": [
          "synonymous",
          "silent",
          "同义"
        ],
        "examples": [
          "TP53 P72P"
        ]
      },

      "hotspot": {
        "description": "Hotspot mutation",
        "patterns": [
          "hotspot",
          "recurrent mutation",
          "driver mutation",
          "热点突变"
        ],
        "examples": [
          "BRAF V600E",
          "KRAS G12C",
          "IDH1 R132H"
        ]
      }

    }
  },

  "indel": {

    "description": "Insertion / Deletion Variants",

    "subtypes": {

      "frameshift": {
        "description": "Frameshift mutation",
        "patterns": [
          "frameshift",
          "frame.?shift",
          "fs",
          "fs\\*",
          "移码"
        ],
        "examples": [
          "BRCA1 E23fs",
          "p.Glu23ArgfsTer17"
        ]
      },

      "inframe_deletion": {
        "description": "In-frame deletion",
        "patterns": [
          "in.?frame deletion",
          "del",
          "deletion",
          "框内缺失"
        ],
        "examples": [
          "EGFR exon 19 deletion",
          "EGFR Ex19del",
          "EGFR E746_A750del"
        ]
      },

      "inframe_insertion": {
        "description": "In-frame insertion",
        "patterns": [
          "in.?frame insertion",
          "ins",
          "insertion",
          "框内插入"
        ],
        "examples": [
          "EGFR exon20 insertion",
          "EGFR A763_Y764insFQEA"
        ]
      },

      "duplication": {
        "description": "Duplication",
        "patterns": [
          "dup",
          "duplication",
          "重复"
        ],
        "examples": [
          "FLT3-ITD",
          "BRCA1 dup"
        ]
      }

    }
  },

  "cnv": {

    "description": "Copy Number Variants",

    "subtypes": {

      "amplification": {
        "description": "Gene amplification",
        "patterns": [
          "amplification",
          "amplified",
          "copy.?number amplification",
          "copy.?number gain",
          "copy gain",
          "high copy number",
          "CNV",
          "扩增"
        ],
        "examples": [
          "ERBB2 amplification",
          "EGFR amplification",
          "MET amplification"
        ]
      },

      "gain": {
        "description": "Copy number gain",
        "patterns": [
          "gain",
          "copy gain",
          "copy.?number gain"
        ],
        "examples": [
          "FGFR1 gain"
        ]
      },

      "loss": {
        "description": "Copy number loss",
        "patterns": [
          "copy.?number loss",
          "loss",
          "copy loss"
        ],
        "examples": [
          "PTEN loss"
        ]
      },

      "homozygous_deletion": {
        "description": "Homozygous deletion",
        "patterns": [
          "homozygous deletion",
          "biallelic deletion",
          "deep deletion",
          "LOH",
          "loss of heterozygosity",
          "纯合缺失"
        ],
        "examples": [
          "CDKN2A homozygous deletion"
        ]
      }

    }
  },

  "structural_variant": {

    "description": "Structural Variants",

    "subtypes": {

      "fusion": {
        "description": "Gene fusion",
        "patterns": [
          "fusion",
          "gene fusion",
          "fusion gene",
          "fusion transcript",
          "fusion-positive",
          "[A-Z0-9]+-[A-Z0-9]+"
        ],
        "examples": [
          "EML4-ALK",
          "BCR-ABL1",
          "ETV6-NTRK3"
        ]
      },

      "rearrangement": {
        "description": "Gene rearrangement",
        "patterns": [
          "rearrangement",
          "gene rearrangement",
          "rearranged",
          "重排"
        ],
        "examples": [
          "RET rearrangement"
        ]
      },

      "translocation": {
        "description": "Chromosomal translocation",
        "patterns": [
          "translocation",
          "易位",
          "t\\([0-9XY;]+\\)"
        ],
        "examples": [
          "t(9;22)"
        ]
      },

      "inversion": {
        "description": "Chromosomal inversion",
        "patterns": [
          "inversion",
          "倒位"
        ],
        "examples": [
          "EML4-ALK inversion"
        ]
      }

    }
  },

  "rna_variant": {

    "description": "RNA-level Variants",

    "subtypes": {

      "splice_site": {
        "description": "Splice-site mutation",
        "patterns": [
          "splice",
          "splice.?site",
          "splicing",
          "剪接",
          "\\+\\d+[ACGT]>[ACGT]",
          "-\\d+[ACGT]>[ACGT]"
        ],
        "examples": [
          "BRCA1 c.594-2A>C"
        ]
      },

      "exon_skipping": {
        "description": "Exon skipping",
        "patterns": [
          "exon.?skipping",
          "skipping",
          "外显子跳跃"
        ],
        "examples": [
          "MET exon 14 skipping"
        ]
      }

    }
  },

  "hgvs": {

    "description": "HGVS Variant Nomenclature",

    "subtypes": {

      "protein": {
        "description": "Protein HGVS",
        "patterns": [
          "p\\.[A-Za-z]{3}\\d+[A-Za-z]{3}",
          "p\\.[A-Za-z]{3}\\d+Ter",
          "p\\.[A-Za-z]{3}\\d+fs"
        ],
        "examples": [
          "p.Val600Glu",
          "p.Arg213Ter"
        ]
      },

      "coding_dna": {
        "description": "Coding DNA HGVS",
        "patterns": [
          "c\\.\\d+[ACGT]>[ACGT]",
          "c\\.\\d+_\\d+del",
          "c\\.\\d+_\\d+ins",
          "c\\.\\d+dup"
        ],
        "examples": [
          "c.1799T>A",
          "c.2235_2249del15"
        ]
      },

      "genomic": {
        "description": "Genomic HGVS",
        "patterns": [
          "g\\.\\d+[ACGT]>[ACGT]"
        ],
        "examples": [
          "g.140453136A>T"
        ]
      }
    }
  },

  "epigenetic": {

    "description": "Epigenetic Alterations",

    "subtypes": {

      "methylation": {
        "description": "DNA methylation",
        "patterns": [
          "methylation",
          "hypermethylation",
          "hypomethylation",
          "promoter methylation",
          "甲基化"
        ],
        "examples": [
          "MGMT promoter methylation",
          "MLH1 hypermethylation"
        ]
      },

      "acetylation": {
        "description": "Histone acetylation",
        "patterns": [
          "acetylation",
          "histone acetylation",
          "乙酰化"
        ],
        "examples": [
          "H3K27 acetylation"
        ]
      }
    }
  }
}
