"""
Gradio Web 界面 — Bioinformatics Agent 前端。
"""
import gradio as gr
from typing import Generator

from src.agent.executor import execute_research, _snapshot
from src.ui.report_renderer import (
    render_execution_log,
    render_task_plan,
    format_report_html,
)

TITLE = """
# Bioinformatics Literature Research Agent
### AI 驱动的生物医学文献智能分析系统

输入你的研究意图，Agent 将自动完成：
**文献检索 → 信息提取 → 跨文献对比 → 结构化报告**
"""


def run_research(
    query: str,
    max_papers: int = 5,
) -> Generator[tuple[str, str, str, str], None, None]:
    """执行研究流程，逐步 yield 四个 Tab 的内容更新"""
    if not query.strip():
        yield (
            render_task_plan([]),
            render_execution_log(["等待输入研究问题..."]),
            "*尚无对比报告*",
            "*尚无最终报告*",
        )
        return

    for snapshot in execute_research(query=query, max_papers=max_papers):
        plan_html = render_task_plan(snapshot.get("sub_tasks", []))
        log_html = render_execution_log(snapshot.get("execution_log", []))

        # 对比报告（中间产物）
        compare_md = snapshot.get("comparison_report", "")
        if not compare_md:
            compare_md = "*对比分析进行中...*"

        # 最终报告
        final_md = format_report_html(snapshot.get("final_report", ""))

        yield (plan_html, log_html, compare_md, final_md)


def create_ui() -> gr.Blocks:
    """创建 Gradio 界面"""
    with gr.Blocks(
        title="Bioinformatics Agent",
        theme=gr.themes.Soft(),
        css="""
        .execution-timeline { max-height: 400px; overflow-y: auto; }
        .task-dag { max-height: 400px; overflow-y: auto; }
        """,
    ) as demo:
        gr.Markdown(TITLE)

        with gr.Row():
            # ── 左侧：输入面板 ──
            with gr.Column(scale=1, min_width=300):
                gr.Markdown("### 研究问题")
                query_input = gr.Textbox(
                    label="输入你的生物医学研究意图",
                    placeholder="例如：对比近三年针对 EGFR 靶点的 NSCLC 临床研究中 PD-1 抑制剂的疗效数据...",
                    lines=4,
                )
                max_papers_slider = gr.Slider(
                    label="最大文献数",
                    minimum=2,
                    maximum=20,
                    value=5,
                    step=1,
                )
                submit_btn = gr.Button("开始研究", variant="primary", size="lg")

                gr.Markdown("""
                ---
                **使用提示：**
                1. 输入具体的研究问题（含靶点、疾病、干预方式）
                2. 等待 Agent 自动拆解任务并执行
                3. 查看各 Tab 了解详细执行过程
                """)

            # ── 右侧：结果展示 ──
            with gr.Column(scale=2, min_width=500):
                with gr.Tabs():
                    with gr.TabItem("任务规划 (DAG)"):
                        plan_display = gr.HTML(
                            value=render_task_plan([]),
                            label="执行计划",
                        )

                    with gr.TabItem("执行过程"):
                        log_display = gr.HTML(
                            value=render_execution_log([]),
                            label="实时日志",
                        )

                    with gr.TabItem("对比分析"):
                        compare_display = gr.Markdown(
                            value="*尚无对比报告*",
                            label="跨文献对比",
                        )

                    with gr.TabItem("最终报告"):
                        report_display = gr.Markdown(
                            value=format_report_html(""),
                            label="文献概览报告",
                            latex_delimiters=[
                                {"left": "$$", "right": "$$", "display": True},
                                {"left": "$", "right": "$", "display": False},
                            ],
                        )

        # ── 事件绑定 ──
        submit_btn.click(
            fn=run_research,
            inputs=[query_input, max_papers_slider],
            outputs=[plan_display, log_display, compare_display, report_display],
        )

    return demo
