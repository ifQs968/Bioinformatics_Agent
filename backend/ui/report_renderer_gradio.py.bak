"""
报告渲染工具 — Markdown 转 HTML，支持图文就地渲染和来源标注。
"""
import re
from datetime import datetime


def render_execution_log(logs: list[str]) -> str:
    """将执行日志列表渲染为 HTML 时间线"""
    if not logs:
        return "<p style='color: #666;'>等待执行...</p>"

    html_parts = ['<div class="execution-timeline">']
    for i, log in enumerate(logs):
        color = "#4a90d9"
        icon = "&#9678;"
        if "失败" in log or "错误" in log or "Error" in log:
            color = "#e74c3c"
            icon = "&#10007;"
        elif "完成" in log or "完毕" in log:
            color = "#27ae60"
            icon = "&#10003;"

        log_escaped = log.replace("<", "&lt;").replace(">", "&gt;")
        html_parts.append(
            f'<div style="margin:4px 0; padding:4px 8px; '
            f'border-left:3px solid {color}; font-size:13px;">'
            f'<span style="color:{color};">{icon}</span> {log_escaped}'
            f'</div>'
        )
    html_parts.append("</div>")
    return "\n".join(html_parts)


def render_task_plan(sub_tasks: list[dict]) -> str:
    """将任务 DAG 渲染为可视化 HTML"""
    if not sub_tasks:
        return "<p style='color: #666;'>任务尚未规划</p>"

    type_labels = {
        "search": "[检索]",
        "parse": "[解析]",
        "compare": "[对比]",
        "report": "[报告]",
    }
    status_icons = {
        "pending": "&#9679;",
        "running": "&#9654;",
        "done": "&#10003;",
        "failed": "&#10007;",
    }
    status_colors = {
        "pending": "#999",
        "running": "#4a90d9",
        "done": "#27ae60",
        "failed": "#e74c3c",
    }

    html_parts = ['<div class="task-dag">']
    for task in sub_tasks:
        ttype = task.get("type", "")
        label = type_labels.get(ttype, f"[{ttype}]")
        status = task.get("status", "pending")
        icon = status_icons.get(status, "?")
        color = status_colors.get(status, "#999")

        deps = task.get("depends_on", [])
        dep_str = f" &#8592; {', '.join(deps)}" if deps else ""

        html_parts.append(
            f'<div style="margin:8px 0; padding:8px 12px; '
            f'border:1px solid {color}; border-radius:6px; '
            f'border-left:4px solid {color}; font-size:14px;">'
            f'<span style="color:{color}; margin-right:6px;">{icon}</span>'
            f'<strong style="color:{color};">{label}</strong> '
            f'{task.get("description", "")}'
            f'<span style="color:#999; font-size:12px;">{dep_str}</span>'
            f'</div>'
        )
    html_parts.append("</div>")
    return "\n".join(html_parts)


def format_report_html(markdown_report: str) -> str:
    """将 Markdown 报告包装为适合 Gradio 展示的 HTML"""
    # Gradio 的 gr.Markdown 组件直接支持 Markdown 渲染，
    # 这里只做必要的预处理，如时间戳追加
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    if markdown_report:
        return markdown_report + f"\n\n---\n*Generated at {timestamp}*"
    return f"*报告尚未生成，请先输入研究问题并提交。*\n\n*---*\n*{timestamp}*"
